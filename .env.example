# ─────────────────────────────────────────────
# LIVE A LITTLE — Environment Variables
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/live_a_lil?schema=public"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (magic link emails)
# Get from: resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Live A Little <hello@liveali.app>"

# Anthropic (AI engine)
# Get from: console.anthropic.com/api-keys
ANTHROPIC_API_KEY=""

# Upstash Redis (caching)
# Get from: console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare R2 / AWS S3 (media storage)
# For R2: use account ID from cloudflare.com dashboard
STORAGE_BUCKET=""
STORAGE_REGION="auto"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""          # e.g., https://<account-id>.r2.cloudflarestorage.com
STORAGE_PUBLIC_URL=""        # Public URL prefix for uploaded files

# Unsplash API (item images)
# Get from: unsplash.com/developers
UNSPLASH_ACCESS_KEY=""
